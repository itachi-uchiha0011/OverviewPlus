# ========================================
# Overview+ App Environment Configuration
# ========================================

# ---------------------
# General App Settings
# ---------------------
SECRET_KEY=your_random_secret_key_here
APP_NAME=Overview+
APP_URL=http://localhost:5000
ENV=development
DEBUG=True

# ---------------------
# Database
# ---------------------
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/overview_plus
# Example for PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/overview_plus

# ---------------------
# Email (SMTP)
# ---------------------
SMTP_SERVER=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
EMAIL_FROM=overviewplus@example.com

# ---------------------
# Telegram Bot
# ---------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id_here

# ---------------------
# Cloud Storage (Optional)
# ---------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=ap-south-1

# ---------------------
# Web Push Notifications (Optional)
# ---------------------
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=admin@example.com

# ---------------------
# Timezone & Preferences
# ---------------------
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_THEME=light